# Kopiere zu .env.local und fuelle die Werte ein.
# .env.local wird via .gitignore NICHT committet.

# === macOS Code-Signing + Notarization ===
# CSC_LINK: absoluter Pfad ODER base64-encoded .p12-Cert.
# electron-builder akzeptiert beides.
# CSC_LINK=/Users/du/certs/fleet-os-mac-cert.p12
# CSC_KEY_PASSWORD=dein-p12-passwort

# Notarization via Apple notarytool
# APPLE_ID=du@apple-id.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=ABC123XYZ4

# === Windows Code-Signing ===
# WIN_CSC_LINK: absoluter Pfad zum .pfx-Cert
# WIN_CSC_LINK=C:\certs\fleet-os-windows-cert.pfx
# WIN_CSC_KEY_PASSWORD=dein-pfx-passwort

# === Optional Dev-Override ===
# ELECTRON_DEV_URL=http://localhost:3000
